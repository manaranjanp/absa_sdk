# =============================================================================
# ABSA Agent System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# At minimum, configure ONE LLM provider key.

# --- LLM Provider API Keys (configure at least one) ---
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
XAI_API_KEY=your-xai-grok-api-key-here

# --- LangSmith Observability (optional but recommended) ---
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=absa-agent-pipeline
LANGSMITH_TRACING=true

# --- Default Model Selection ---
# Supported formats: openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022,
#   google/gemini-2.0-flash, groq/llama3-8b-8192, xai/grok-2
DEFAULT_MODEL=openai/gpt-4o

